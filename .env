PORT=3000
NODE_ENV=development
SESSION_SECRET=local-dev-secret-change-in-production

# Database - update with your local PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/mycabtax

# Auth0 - leave blank to run without auth (dev mode), or fill in real credentials
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_CLIENT_ID=your_client_id
# AUTH0_CLIENT_SECRET=your_client_secret

# Stripe (optional for local dev)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Google Cloud (optional for local dev)
# GOOGLE_CLOUD_PROJECT=...
# GOOGLE_APPLICATION_CREDENTIALS=...
